#!/bin/bash
# Pre-commit hook: block platform-specific constructs without wrappers
# Install: git config core.hooksPath .githooks
# See: docs/PLATFORM-COMPAT.md

ISSUES=0

# === Block secrets file from being committed ===
if git diff --cached --name-only 2>/dev/null | grep -q '\.exocortex\.env'; then
    echo "SECURITY: .exocortex.env is staged for commit — this file contains secrets!"
    echo "  Remove from staging: git restore --staged .exocortex.env"
    echo "  The file is in .gitignore — verify it's listed there."
    exit 1
fi

# === CHANGELOG ↔ update-manifest.json version sync ===
# Корень бага (25 апр): drift на 5 версий между CHANGELOG (0.27.7) и
# manifest (0.26.1) — update.sh --check отдавал «нет обновлений», пока
# пользователь не словил это вручную. Память не помогает; нужен harness-гейт.
# Правило: top version в CHANGELOG.md == version в update-manifest.json. Всегда.
# Допущение: новая секция в CHANGELOG.md ВСЕГДА вверху (Keep-a-Changelog convention).
# Если кто-то вставит секцию НЕ в начало — top-grep вернёт старую версию, drift
# не задетектится. Это сознательный trade-off (alternative — счёт секций — даёт FP).

# (C) Hard-fail при переименовании/перемещении: эти файлы имеют контракт с update.sh,
# двигать их нельзя.
RENAMED_RELEASE_FILES=$(git diff --cached --name-status 2>/dev/null \
    | grep -E '^R[0-9]*[[:space:]].*(CHANGELOG\.md|update-manifest\.json)' || true)
if [ -n "$RENAMED_RELEASE_FILES" ]; then
    echo "RELEASE-SYNC: обнаружен rename CHANGELOG.md или update-manifest.json"
    echo "  Эти файлы имеют контракт с update.sh — путь должен быть в корне репо."
    echo "  Затронуто: $RENAMED_RELEASE_FILES"
    exit 1
fi

STAGED_RELEASE_FILES=$(git diff --cached --name-only 2>/dev/null \
    | grep -E '^(CHANGELOG\.md|update-manifest\.json)$' || true)
if [ -n "$STAGED_RELEASE_FILES" ]; then
    if [ -f "CHANGELOG.md" ] && [ -f "update-manifest.json" ]; then
        CHANGELOG_VERSION=$(grep -m1 -oE '^## \[[0-9]+\.[0-9]+\.[0-9]+\]' CHANGELOG.md \
            | sed 's/^## \[//;s/\]$//' || true)
        MANIFEST_VERSION=$(grep -m1 '"version"' update-manifest.json \
            | sed 's/.*"version"[[:space:]]*:[[:space:]]*"//;s/".*//' || true)

        if [ -z "$CHANGELOG_VERSION" ]; then
            echo "RELEASE-SYNC: не удалось извлечь version из CHANGELOG.md (top section)"
            echo "  Ожидаем строку вида: ## [X.Y.Z] — YYYY-MM-DD"
            exit 1
        fi
        if [ -z "$MANIFEST_VERSION" ]; then
            echo "RELEASE-SYNC: не удалось извлечь version из update-manifest.json"
            exit 1
        fi
        if [ "$CHANGELOG_VERSION" != "$MANIFEST_VERSION" ]; then
            echo "RELEASE-SYNC: рассинхрон версий!"
            echo "  CHANGELOG.md top:        $CHANGELOG_VERSION"
            echo "  update-manifest.json:    $MANIFEST_VERSION"
            echo ""
            echo "  update.sh --check парсит manifest, не CHANGELOG. При расхождении"
            echo "  пользователи не получают обновлений (drift 25 апр: 5 версий)."
            echo ""
            echo "  Fix: bump version в update-manifest.json до $CHANGELOG_VERSION"
            echo "       (или откатить новую секцию в CHANGELOG, если bump преждевременный)"
            exit 1
        fi
        echo "RELEASE-SYNC: PASS ($CHANGELOG_VERSION)"
    fi
fi

# === Promote script dry-run smoke (PD-2, WP-347) ===
# Корень бага (20 мая): settings-promote.sh ломался на pre-existing debt в env -i —
# найдено Kimi-агентом после того как автор не заметил в авторском env.
# Гейт: при staged promote-скриптах запускаем сам promote с фикстурой в env -i.
STAGED_PROMOTE=$(git diff --cached --name-only --diff-filter=ACM 2>/dev/null \
    | grep -E '^scripts/(settings|hook|script|skill)-promote\.sh$' || true)
if [ -n "$STAGED_PROMOTE" ] && [ -d "setup/promote-fixtures" ]; then
    FAIL=0
    for promote in $STAGED_PROMOTE; do
        case "$(basename "$promote")" in
            script-promote.sh)
                CMD="bash scripts/script-promote.sh setup/promote-fixtures/sample-script.sh --dry-run"
                ;;
            hook-promote.sh)
                CMD="bash scripts/hook-promote.sh setup/promote-fixtures/sample-hook.sh --dry-run"
                ;;
            settings-promote.sh)
                CMD="bash scripts/settings-promote.sh sample-hook.sh PreToolUse --matcher Bash --dry-run"
                ;;
            skill-promote.sh)
                CMD="bash scripts/skill-promote.sh setup/promote-fixtures/sample-skill --dry-run"
                ;;
        esac
        if ! env -i HOME="$HOME" PATH="$PATH" $CMD >/tmp/iwe-promote-dryrun.$$ 2>&1; then
            echo "PROMOTE-DRY-RUN: $promote FAIL"
            cat /tmp/iwe-promote-dryrun.$$
            rm -f /tmp/iwe-promote-dryrun.$$
            FAIL=1
        else
            echo "PROMOTE-DRY-RUN: $promote PASS"
            rm -f /tmp/iwe-promote-dryrun.$$
        fi
    done
    if [ "$FAIL" -eq 1 ]; then
        echo "  Override: git commit --no-verify (только если уверен)"
        exit 1
    fi
fi

# === Clean-env smoke for new scripts (PD-1, WP-347) ===
# Корень: новые scripts/*.sh могут работать у автора (с авторскими env vars),
# но падать у пользователей. Гейт: при staged НОВОМ файле scripts/*.sh —
# прогон smoke-clean-env.sh (bash -n + safe-mode check + shebang + optional --help в env -i).
STAGED_NEW_SCRIPTS=$(git diff --cached --name-status --diff-filter=A 2>/dev/null \
    | awk '$2 ~ /^scripts\/.*\.sh$/ {print $2}' || true)
if [ -n "$STAGED_NEW_SCRIPTS" ] && [ -x "scripts/smoke-clean-env.sh" ]; then
    FAIL=0
    for script in $STAGED_NEW_SCRIPTS; do
        # Skip promote-скрипты (они тестируются отдельным гейтом PROMOTE-DRY-RUN)
        case "$(basename "$script")" in
            *-promote.sh) continue ;;
        esac
        if ! bash scripts/smoke-clean-env.sh "$script" >/tmp/iwe-cleanenv.$$ 2>&1; then
            echo "CLEAN-ENV-SMOKE: $script FAIL"
            cat /tmp/iwe-cleanenv.$$
            rm -f /tmp/iwe-cleanenv.$$
            FAIL=1
        else
            cat /tmp/iwe-cleanenv.$$
            rm -f /tmp/iwe-cleanenv.$$
        fi
    done
    if [ "$FAIL" -eq 1 ]; then
        echo "  Override: git commit --no-verify"
        exit 1
    fi
fi

# === Hook paths convention (.claude/settings.json) ===
# Корень бага (20 мая 2026): settings.json вручную скопирован в FMT с относительными
# путями .claude/hooks/X.sh. При сдвиге cwd (subagent/worktree/MCP) хук не находится.
# Конвенция: все хук-команды должны начинаться с $CLAUDE_PROJECT_DIR/.
STAGED_SETTINGS=$(git diff --cached --name-only --diff-filter=ACM 2>/dev/null \
    | grep -E '^\.claude/settings\.json$' || true)
if [ -n "$STAGED_SETTINGS" ] && [ -x "scripts/validate-fmt-scripts.sh" ]; then
    # FMT7 (#150): валидировать только staged-скрипты, а не весь scripts/ —
    # иначе pre-existing долг в чужом файле блокирует регистрацию нового хука.
    STAGED_SCRIPTS=$(git diff --cached --name-only --diff-filter=ACM 2>/dev/null \
        | grep -E '\.(sh|py)$' || true)
    if [ -n "$STAGED_SCRIPTS" ]; then
        # shellcheck disable=SC2086
        if ! bash scripts/validate-fmt-scripts.sh --files $STAGED_SCRIPTS >/tmp/iwe-settings-validate.$$ 2>&1; then
            echo "HOOK-PATH-CONVENTION: FAIL"
            cat /tmp/iwe-settings-validate.$$
            rm -f /tmp/iwe-settings-validate.$$
            echo ""
            echo "  Используй settings-promote.sh для регистрации новых хуков."
            echo "  Override: git commit --no-verify"
            exit 1
        fi
        rm -f /tmp/iwe-settings-validate.$$
    fi
fi

# === Template validation (author-specific leaks, hardcoded paths, hooks cross-ref) ===
# Корень бага (26 апр): литерал `DS-my-strategy` попал в новый
# templates/strategy-skeleton/README.md (commit cb22aaa); валидатор зовётся
# только из template-sync.sh — ручные коммиты в FMT валидацию обходили.
# Гейт: если staged хоть один файл из расширений, что сканит validate-template.sh,
# прогнать полную валидацию шаблона. Escape hatch: `git commit --no-verify`.
# B9 fix (0.28.5): валидация ВЫШЕ exit STAGED_SH — иначе md/yaml/json-only
# коммиты пропускали проверку и пускали leak в FMT.
STAGED_TEMPLATE=$(git diff --cached --name-only --diff-filter=ACM 2>/dev/null \
    | grep -E '\.(md|sh|py|json|plist|yaml)$' || true)
# Bootstrap TEMPLATE_DIR from .exocortex.env (parent of this repo) — no env var required
if [ -z "${TEMPLATE_DIR:-}" ]; then
  _repo_root=$(git rev-parse --show-toplevel 2>/dev/null || true)
  _env_file="$(dirname "${_repo_root:-}")/.exocortex.env"
  if [ -f "$_env_file" ]; then
    _td=$(grep '^IWE_TEMPLATE=' "$_env_file" | head -1 | cut -d= -f2-)
    [ -n "${_td:-}" ] && export TEMPLATE_DIR="$_td"
    unset _td
  fi
  unset _repo_root _env_file
fi
if [ -n "$STAGED_TEMPLATE" ] && [ -x "setup/validate-template.sh" ]; then
    # --mode=staged: проверяет только staged файлы. Предотвращает ложные блокировки
    # от unstaged WIP параллельных агентов (мультиагентная среда IWE). CI использует pristine.
    if ! bash setup/validate-template.sh --mode=staged ${TEMPLATE_DIR:+"$TEMPLATE_DIR"} >/tmp/iwe-validate.$$ 2>&1; then
        echo "TEMPLATE-VALIDATE: FAIL"
        cat /tmp/iwe-validate.$$
        rm -f /tmp/iwe-validate.$$
        echo ""
        echo "  Commit blocked. Fix issues above or override with: git commit --no-verify"
        exit 1
    fi
    rm -f /tmp/iwe-validate.$$
fi

# === Integration contract validator (Spec↔State drift detection) ===
# Корень бага (29 апр, 0.29.13 регрессия): template-sync перезаписал FMT файлы
# из авторского pre-0.29.5 IWE → 8 violations. Євгений нашёл на fresh clone, но
# наш собственный валидатор НЕ запускался при коммите. Гейт: тот же скрипт что
# Євгений, на наших же staged файлах. Escape hatch: `git commit --no-verify`.
# Запускаем только если staged файлы из scope валидатора (roles/, .claude/, setup/,
# memory/, extensions/, update-manifest.json).
STAGED_VALIDATOR_SCOPE=$(git diff --cached --name-only --diff-filter=ACM 2>/dev/null \
    | grep -E '^(roles/|\.claude/|setup/|memory/|extensions/|seed/|update-manifest\.json)' || true)
if [ -n "$STAGED_VALIDATOR_SCOPE" ] && [ -x "setup/integration-contract-validator.sh" ]; then
    if ! bash setup/integration-contract-validator.sh >/tmp/iwe-icv.$$ 2>&1; then
        echo "INTEGRATION-CONTRACT-VALIDATOR: FAIL"
        cat /tmp/iwe-icv.$$
        rm -f /tmp/iwe-icv.$$
        echo ""
        echo "  Commit blocked. Fix detector violations above or override with: git commit --no-verify"
        exit 1
    fi
    rm -f /tmp/iwe-icv.$$
fi

# === Detector regex regression tests (0.29.18) ===
# Если staged изменения в integration-contract-validator.sh ИЛИ в detector-fixtures/
# — прогнать test-detectors.sh. Ловит regex-gap регрессии в самих detector'ах.
STAGED_DETECTOR_SCOPE=$(git diff --cached --name-only --diff-filter=ACM 2>/dev/null \
    | grep -E '^setup/(integration-contract-validator\.sh|detector-fixtures/|test-detectors\.sh)' || true)
if [ -n "$STAGED_DETECTOR_SCOPE" ] && [ -x "setup/test-detectors.sh" ]; then
    if ! bash setup/test-detectors.sh >/tmp/iwe-detector-tests.$$ 2>&1; then
        echo "DETECTOR-REGEX-TESTS: FAIL"
        cat /tmp/iwe-detector-tests.$$
        rm -f /tmp/iwe-detector-tests.$$
        echo ""
        echo "  Detector regex регрессировал — historical fixture больше не ловится."
        echo "  Override: git commit --no-verify"
        exit 1
    fi
    rm -f /tmp/iwe-detector-tests.$$
fi

# === Manifest coverage check (MG5) ===
# Корень бага (25 мая): orphan-скрипты (day-open-scaffold.sh, iwe-backup-check.sh,
# route-task.sh) попали в git, но не в update-manifest.json → partial delivery.
# Shift-left: ловим ДО коммита, а не в CI.
STAGED_MANIFEST_SCOPE=$(git diff --cached --name-only --diff-filter=ACM 2>/dev/null \
    | grep -E '^(scripts/|\.claude/|roles/|exocortex/|memory/|\.githooks/|pack-templates/|shared/|update-manifest\.json)' || true)
if [ -n "$STAGED_MANIFEST_SCOPE" ] && [ -f "scripts/check-manifest-coverage.py" ]; then
    if ! git ls-files | python3 scripts/check-manifest-coverage.py update-manifest.json >/tmp/iwe-manifest.$$ 2>&1; then
        echo "MANIFEST-COVERAGE: FAIL"
        cat /tmp/iwe-manifest.$$
        rm -f /tmp/iwe-manifest.$$
        echo ""
        echo "  Commit blocked. Добавь orphan-файл(ы) в update-manifest.json"
        echo "  или в excluded_paths, если намеренно исключён."
        echo "  Override: git commit --no-verify"
        exit 1
    fi
    rm -f /tmp/iwe-manifest.$$
fi

# Get list of staged .sh files
STAGED_SH=$(git diff --cached --name-only --diff-filter=ACM -- '*.sh' 2>/dev/null)
[ -z "$STAGED_SH" ] && exit 0

check_pattern() {
    local pattern="$1"
    local description="$2"
    local exclude="${3:-}"

    for file in $STAGED_SH; do
        # Skip PLATFORM-COMPAT.md references
        [ "$(basename "$file")" = "PLATFORM-COMPAT.md" ] && continue

        # Check staged content (not working tree)
        local matches
        if [ -n "$exclude" ]; then
            matches=$(git show ":$file" 2>/dev/null | grep -n "$pattern" | grep -v "$exclude" || true)
        else
            matches=$(git show ":$file" 2>/dev/null | grep -n "$pattern" || true)
        fi

        if [ -n "$matches" ]; then
            echo "PLATFORM-COMPAT: $description"
            echo "  File: $file"
            echo "$matches" | while read line; do echo "  $line"; done
            echo "  Fix: docs/PLATFORM-COMPAT.md"
            echo ""
            ISSUES=1
        fi
    done
}

check_pattern "sed -i ''" "raw sed -i '' (use sed_inplace)" "sed_inplace"
check_pattern "date -v-" "raw date -v (use portable_date_offset)" "portable_date_offset\|2>/dev/null"
check_pattern "readlink -f" "readlink -f (not portable)"
check_pattern "grep -P " "grep -P (GNU-only, use grep -E)"

if [ "$ISSUES" -eq 1 ]; then
    echo "Commit blocked. See docs/PLATFORM-COMPAT.md for cross-platform wrappers."
    exit 1
fi

# === WP-387: diagnose-iwe rubric sync check ===
# Ensures derived SKILL.md is in sync with YAML SoT
if git diff --cached --name-only | grep -qE "shared/rubrics/|\.claude/skills/diagnose-iwe/"; then
  if [ -f "scripts/generate-diagnose-iwe-skill.py" ]; then
    python3 scripts/generate-diagnose-iwe-skill.py --check || {
      echo ""
      echo "RUBRIC-SYNC: diagnose-iwe/SKILL.md is out of sync with shared/rubrics/form-089.yaml"
      echo "  Run: python3 scripts/generate-diagnose-iwe-skill.py --check"
      echo "  Then update SKILL.md manually to match YAML, stage both, retry commit."
      exit 1
    }
  fi
fi
